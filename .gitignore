# Keep these empty directories
!/build
/build/**
!/output
/output/**

# Ignore doxygen output
/docs/doxygen

# Allow per-user settings and debug states
.cache/
/.vscode/
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# MacOS
*.DS_Store

# Autogenerated files
can_library/generated/
can_library/dbc/

# Dont include venv and local dependencies
venv
.venv