{% set file_name = "fault_data.c" %}
{% set file_brief = "Auto-generated implementation of the system-wide fault library." %}
{% include "common/file_banner.jinja" %}

#include "can_library/generated/fault_data.h"
#include "can_library/generated/can_router.h"

fault_t faults[TOTAL_NUM_FAULTS] = {
{% for module in fault_modules %}
    // --- {{ module.node_name }} ---
{% for fault in module.faults %}
    [{{ fault.id }}] = {
        .start_time_ms = 0,
        .max_value = {{ fault.max_val }},
        .min_value = {{ fault.min_val }},
        .latch_time_ms = {{ fault.latch_time }},
        .unlatch_time_ms = {{ fault.unlatch_time }},
        .state = FAULT_STATE_LATCHED, // start latched to sync initial state across MCUs
        .priority = {{ fault.priority_macro }}
    },
{% endfor %}
{% endfor %}
};

#ifdef HAS_FAULT_STRINGS
const char* const fault_strings[TOTAL_NUM_FAULTS] = {
{% for module in fault_modules %}
    // --- {{ module.node_name }} ---
{% for fault in module.faults %}
    [{{ fault.id }}] = {{ fault.lcd_literal }},
{% endfor %}
{% endfor %}
};
#endif

{% for module in fault_modules %}
// --- {{ module.node_name }} Callbacks ---
#ifdef FAULT_LIB_ENABLED
#ifndef CAN_NODE_{{ module.node_macro }}
void {{ module.sync_callback }}() {
{% for fault in module.faults %}
    {{ fault.sync_assignment }}
{% endfor %}
}

void {{ module.event_callback }}() {
    uint16_t idx = can_data.{{ module.node_lower }}_fault_event.idx;
    if (idx < TOTAL_NUM_FAULTS) {
        faults[idx].state = (can_data.{{ module.node_lower }}_fault_event.state != 0) ? FAULT_STATE_LATCHED : FAULT_STATE_CLEAR;
    }
}
#else
void {{ module.sync_callback }}() { }
void {{ module.event_callback }}() { }
#endif
#endif

{% endfor %}
// --- Transmission Helpers ---
void tx_fault_sync(void) {
#ifdef FAULT_LIB_ENABLED
{% for module in fault_modules %}
#ifdef CAN_NODE_{{ module.node_macro }}
    {{ module.sync_sender }}(
{% for fault in module.faults %}
        {{ fault.sync_arg }}{{ "," if not loop.last }}
{% endfor %}
    );
#endif
{% endfor %}
#endif
}

void tx_fault_event(fault_id_t idx, uint16_t value) {
#ifdef FAULT_LIB_ENABLED
{% for module in fault_modules %}
#ifdef CAN_NODE_{{ module.node_macro }}
    if (idx >= {{ module.first_fault_id }} && idx <= {{ module.last_fault_id }}) {
        {{ module.event_sender }}(idx, (faults[idx].state == FAULT_STATE_LATCHED), value);
    }
#endif
{% endfor %}
#else
    (void)idx; (void)value;
#endif
}
