                    "unit": "g",
                    "scale": 0.01
                },
                {
                    "sig_name": "Z_axis",
                    "sig_desc": "Acceleration along Z-axis",
                    "type": "int16_t",
                    "unit": "g",
                    "scale": 0.01
                },
                {
                    "sig_name": "temperature",
                    "sig_desc": "IMU Temperature",
                    "type": "int16_t",
                    "unit": "C",
                    "scale": 0.1
                }
