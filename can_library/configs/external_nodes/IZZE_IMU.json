                },
                {
                    "sig_name": "Y_axis",
                    "sig_desc": "Angular Rate around Y-axis",
                    "type": "int16_t",
                    "unit": "deg/s",
                    "scale": 0.1
                },
                {
                    "sig_name": "Z_axis",
                    "sig_desc": "Angular Rate around Z-axis",
                    "type": "int16_t",
                    "unit": "deg/s",
                    "scale": 0.1
                },
                {
                    "sig_name": "reserved",
                    "sig_desc": "reserved",
                    "type": "uint16_t"
                }
            ],
            "msg_period": 10,
            "msg_id_override": "0x4EC",
            "msg_priority": 5
        },
        {
            "msg_name": "IZZE_acceleration",
