{
    "node_name": "A_BOX",
    "busses": {
        "VCAN": {
            "peripheral": "FDCAN1",
            "tx": [
                {
                    "msg_name": "pack_stats",
                    "msg_desc": "Pack voltage, current, and temperature",
                    "signals": [
                        {
                            "sig_name": "pack_voltage",
                            "sig_desc": "Total pack voltage",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.01
                        },
                        {
                            "sig_name": "pack_current",
                            "sig_desc": "Total pack current, positive is discharge",
                            "type": "int16_t",
                            "unit": "A",
                            "scale": 0.1
                        },
                        {
                            "sig_name": "avg_temp",
                            "sig_desc": "Average cell temperature in the pack",
                            "type": "int16_t",
                            "unit": "C",
                            "scale": 1
                        }
                    ],
                    "msg_priority": 5,
                    "msg_period": 10
                },
                {
                    "msg_name": "thermistor_telemetry",
                    "msg_desc": "Individual thermistor readings",
                    "signals": [
                        {
                            "sig_name": "thermistor_temperature",
                            "sig_desc": "Individual thermistor temperature",
                            "type": "uint16_t",
                            "unit": "C",
                            "scale": 0.1
                        },
                        {
                            "sig_name": "module_num",
                            "sig_desc": "Module number of the cell being reported, 0 indexed",
                            "type": "uint8_t"
                        },
                        {
                            "sig_name": "thermistor_num",
                            "sig_desc": "Thermistor number within the module, 0 indexed",
                            "type": "uint8_t"
                        }
                    ],
                    "msg_priority": 5,
                    "msg_period": 125
                },
                {
                    "msg_name": "abox_version",
                    "msg_desc": "ABox version",
                    "signals": [
                        {
                            "sig_name": "git_hash",
                            "type": "uint32_t",
                            "sig_desc": "int representation of git short hash"
                        }
                    ],
                    "msg_priority": 5,
                    "msg_period": 5000
                }
            ],
            "rx": [],
            "accept_all_messages": false
        },
        "CCAN": {
            "peripheral": "FDCAN2",
            "tx": [
                {
                    "msg_name": "elcon_command",
                    "msg_desc": "Command from A_BOX to Elcon Charger (Message1)",
                    "byte_order": "big_endian",
                    "signals": [
                        {
                            "sig_name": "voltage_limit",
                            "sig_desc": "Requested charge voltage in decivolts",
                            "unit": "V",
                            "scale": 0.1,
                            "type": "uint16_t"
                        },
                        {
                            "sig_name": "current_limit",
                            "sig_desc": "Requested charge current in deciamps",
                            "unit": "A",
                            "scale": 0.1,
                            "type": "uint16_t"
                        },
                        {
                            "sig_name": "charger_disable",
                            "sig_desc": "0 to enable charging, 1 to disable charging",
                            "type": "uint8_t",
                            "choices": ["ENABLE", "DISABLE"]
                        },
                        {
                            "sig_name": "reserved1",
                            "type": "uint8_t"
                        },
                        {
                            "sig_name": "reserved2",
                            "type": "uint8_t"
                        },
                        {
                            "sig_name": "reserved3",
                            "type": "uint8_t"
                        }
                    ],
                    "msg_priority": 3,
                    "msg_id_override": "0x1806E5F4",
                    "msg_period": 1000
                },
                {
                    "msg_name": "charging_telemetry",
                    "msg_desc": "Reported battery stats during charging",
                    "signals": [
                        {
                            "sig_name": "pack_voltage",
                            "sig_desc": "Total pack voltage",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.01
                        },
                        {
                            "sig_name": "pack_current",
                            "sig_desc": "Total pack current, positive is discharge",
                            "type": "int16_t",
                            "unit": "A",
                            "scale": 0.1
                        },
                        {
                            "sig_name": "min_cell_voltage",
                            "sig_desc": "Minimum cell voltage in the pack",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.01
                        },
                        {
                            "sig_name": "max_cell_voltage",
                            "sig_desc": "Maximum cell voltage in the pack",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.01
                        }
                    ],
                    "msg_priority": 4,
                    "msg_period": 10
                },
                {
                    "msg_name": "charging_fsm_internals",
                    "msg_desc": "Internal states of the charging FSM for debugging purposes",
                    "signals": [
                        {
                            "sig_name": "voltage_limit",
                            "sig_desc": "Requested charge voltage in decivolts",
                            "unit": "V",
                            "scale": 0.1,
                            "type": "uint16_t"
                        },
                        {
                            "sig_name": "current_limit",
                            "sig_desc": "Requested charge current in deciamps",
                            "unit": "A",
                            "scale": 0.1,
                            "type": "uint16_t"
                        },
                        {
                            "sig_name": "balancing_status",
                            "sig_desc": "Balancing status of the pack",
                            "type": "bool"
                        },
                        {
                            "sig_name": "charging_state",
                            "sig_desc": "abox charging fsm state",
                            "type": "charging_state_t"
                        }
                    ],
                    "msg_priority": 4,
                    "msg_period": 1000
                },
                {
                    "msg_name": "cell_telemetry",
                    "msg_desc": "Individual cell voltages and balancing status",
                    "signals": [
                        {
                            "sig_name": "cell_voltage",
                            "sig_desc": "individual cell voltage",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.01
                        },
                        {
                            "sig_name": "module_num",
                            "sig_desc": "Module number of the cell being reported, 0 indexed",
                            "type": "uint8_t"
                        },
                        {
                            "sig_name": "cell_num",
                            "sig_desc": "Cell number within the module, 0 indexed",
                            "type": "uint8_t"
                        },
                        {
                            "sig_name": "balance_status",
                            "sig_desc": "Whether the cell is currently being balanced",
                            "type": "bool"
                        }
                    ],
                    "msg_priority": 5,
                    "msg_period": 10
                }
            ],
            "rx": [
                {
                    "msg_name": "elcon_status"
                },
                {
                    "msg_name": "charge_request"
                }
            ],
            "accept_all_messages": false
        }
    },
    "fault_library_enabled": true,
    "generate_fault_messages": false,
    "faults": [
        {
            "fault_name": "PACK_OVERTEMP",
            "max": 60,
            "min": 0,
            "priority": "error",
            "time_to_latch": 500,
            "time_to_unlatch": 10000,
            "lcd_message": "Pack Temp > 60C"
        },
        {
            "fault_name": "PACK_WARM",
            "max": 50,
            "min": 0,
            "priority": "warning",
            "time_to_latch": 2000,
            "time_to_unlatch": 5000,
            "lcd_message": "Pack Temp > 50C"
        },
        {
            "fault_name": "PACK_COLD",
            "max": 10,
            "min": 0,
            "priority": "error",
            "time_to_latch": 2000,
            "time_to_unlatch": 10000,
            "lcd_message": "Pack Temp < 10C"
        },
        {
            "fault_name": "IMD",
            "max": 1,
            "min": 0,
            "priority": "error",
            "time_to_latch": 100,
            "time_to_unlatch": 5000,
            "lcd_message": "IMD Isolation Fault"
        },
        {
            "fault_name": "BMS_DISCONNECTED",
            "max": 1,
            "min": 0,
            "priority": "error",
            "time_to_latch": 10000,
            "time_to_unlatch": 1000,
            "lcd_message": "BMS Disconnected"
        },
        {
            "fault_name": "CELL_UNDERVOLTAGE",
            "max": 42,
            "min": 27,
            "priority": "error",
            "time_to_latch": 1000,
            "time_to_unlatch": 5000,
            "lcd_message": "Min Cell Voltage < 2.7V"
        },
        {
            "fault_name": "PACK_FULL",
            "max": 520,
            "min": 0,
            "priority": "warning",
            "time_to_latch": 10000,
            "time_to_unlatch": 10000,
            "lcd_message": "Pack Full"
        }
    ]
}
