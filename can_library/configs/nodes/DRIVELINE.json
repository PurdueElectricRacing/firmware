                    "signals": [
                        {
                            "sig_name": "left",
                            "sig_desc": "Length of front left shockpot",
                            "type": "uint16_t",
                            "unit": "mm",
                            "scale": 0.01
                        },
                        {
                            "sig_name": "right",
                            "sig_desc": "Length of front right shockpot",
                            "type": "uint16_t",
                            "unit": "mm",
                            "scale": 0.01
                        }
                    ],
                    "msg_period": 10,
                    "msg_priority": 5
                },
                {
                    "msg_name": "rear_shockpots",
                    "msg_desc": "Shockpot readings from rear left and rear right",
                    "signals": [
                        {
                            "sig_name": "left",
                            "sig_desc": "Length of rear left shockpot",
                            "type": "uint16_t",
                            "unit": "mm",
                            "scale": 0.01
                        },
                        {
                            "sig_name": "right",
                            "sig_desc": "Length of rear right shockpot",
