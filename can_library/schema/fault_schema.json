{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/PER/canpiler/fault_schema.json",
    "type": "object",
    "required": ["fault_name", "max", "min", "priority", "time_to_latch", "time_to_unlatch", "lcd_message"],
    "unevaluatedProperties": false,
    "properties": {
        "fault_name": { "type": "string" },
        "max": { "type": "integer" },
        "min": { "type": "integer" },
        "priority": { "enum": ["warning", "error", "fatal"] },
        "time_to_latch": { "type": "integer", "minimum": 0 },
        "time_to_unlatch": { "type": "integer", "minimum": 0 },
        "lcd_message": { "type": "string", "maxLength": 100 }
    }
}