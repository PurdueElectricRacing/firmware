{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["node_name", "busses", "fault_library_enabled"],
    "additionalProperties": false,
    "properties": {
        "node_name": { "type": "string" },
        "busses": {
            "type": "object",
            "additionalProperties": {
                "$ref": "#/$defs/bus_messages"
            },
            "minProperties": 1
        },
        "fault_library_enabled": {
            "type": "boolean",
            "default": true
        },
        "generate_fault_messages": {
            "type": "boolean"
        },
        "faults": {
            "type": "array",
            "items": { "$ref": "https://github.com/PER/canpiler/fault_schema.json" },
            "uniqueItems": true
        }
    },
    "if": {
        "required": ["faults"]
    },
    "then": {
        "properties": {
            "fault_library_enabled": { "const": true }
        }
    },
    "$defs": {
        "bus_messages": {
            "type": "object",
            "required": ["peripheral"],
            "unevaluatedProperties": false,
            "properties": {
                "peripheral": { "enum": ["CAN1", "CAN2", "FDCAN1", "FDCAN2", "FDCAN3"] },
                "accept_all_messages": { "type": "boolean" },
                "tx": {
                    "type": "array",
                    "items": { "$ref": "https://github.com/PER/canpiler/message_schema.json#/$defs/tx_message" }
                },
                "rx": {
                    "type": "array",
                    "items": { "$ref": "https://github.com/PER/canpiler/message_schema.json#/$defs/rx_message" }
                }
            }
        }
    }
}
