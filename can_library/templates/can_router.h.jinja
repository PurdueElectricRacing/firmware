#ifndef CAN_ROUTER_H
#define CAN_ROUTER_H

{% set file_name = "can_router.h" %}
{% set file_brief = "Auto-generated system-wide CAN node inclusion router." %}
{% include "common/file_banner.jinja" %}

{% for node in router_nodes %}
{% set directive = "#if" if loop.first else "#elif" %}
{{ directive }} defined(CAN_NODE_{{ node.macro_name }})
    #include "can_library/generated/{{ node.name }}.h"
{% endfor %}
{% if router_nodes %}
#endif
{% endif %}

#endif // CAN_ROUTER_H
