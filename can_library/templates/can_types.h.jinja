#ifndef CAN_TYPES_H
#define CAN_TYPES_H

{% set file_name = "can_types.h" %}
{% set file_brief = "Auto-generated custom types and enums for the CAN library." %}
{% include "common/file_banner.jinja" %}

#include <stdint.h>

{% for type in types %}
typedef enum {% if type.base_type %}: {{ type.base_type }}{% endif %} {
{% for choice in type.choices %}
    {{ type.prefix }}_{{ choice|upper }} = {{ loop.index0 }},
{% endfor %}
} {{ type.name }};

{% endfor %}
#endif // CAN_TYPES_H
