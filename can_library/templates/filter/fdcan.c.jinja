// FDCAN filter setup for {{ fdcan_ctx.periph }}
static inline void {{ fdcan_ctx.periph }}_set_filters() {
    {% if fdcan_ctx.accept_all %}
    // Accept all messages - filters configured in PHAL_FDCAN_init() by default
    (void)0;
    {% elif fdcan_ctx.has_filters %}
    {% if fdcan_ctx.std_ids %}
    static uint32_t sid_list[] = {
        {% for msg in fdcan_ctx.std_ids %}
        {{ msg.macro_name }}_MSG_ID{{ "," if not loop.last }}
        {% endfor %}
    };
    {% endif %}

    {% if fdcan_ctx.ext_ids %}
    static uint32_t xid_list[] = {
        {% for msg in fdcan_ctx.ext_ids %}
        {{ msg.macro_name }}_MSG_ID{{ "," if not loop.last }}
        {% endfor %}
    };
    {% endif %}

    PHAL_FDCAN_setFilters(
        {{ fdcan_ctx.periph }},
        {% if fdcan_ctx.std_ids %}
        sid_list, {{ fdcan_ctx.std_ids|length }},
        {% else %}
        NULL, 0,
        {% endif %}
        {% if fdcan_ctx.ext_ids %}xid_list,
        {{ fdcan_ctx.ext_ids|length }}
        {% else %}
        NULL, 0
        {% endif %}
    );
    {% else %}
    // No filters configured
    (void)0;
    {% endif %}
}
