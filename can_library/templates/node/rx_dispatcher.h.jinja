// RX Dispatcher
static inline void CAN_rx_dispatcher(uint32_t id, uint8_t *data, uint8_t len, CAN_bus_t *bus) {
    {% for rx_periph in ctx.rx_peripheral_entries %}
    {{ "if" if loop.first else "else if" }} (bus == {{ rx_periph.peripheral.name }}) {
        switch (id) {
            {% for entry in rx_periph.entries %}
            case {{ entry.msg.macro_name }}_MSG_ID: {
                uint64_t host_data = CAN_load_payload_u64(data, len);

                {% for codec in entry.codecs %}
                uint64_t sig_raw_{{ codec.signal.name }} = CAN_unpack_raw_signal(host_data, {{ codec.signal.mask|to_c_hex }}, {{ codec.signal.bit_shift }}, {{ codec.bswap_width }});
                {% if codec.is_float32 %}
                can_data.{{ entry.msg.name }}.{{ codec.signal.name }} = ({{ codec.signal.c_type }})CAN_raw_to_float32(sig_raw_{{ codec.signal.name }});
                {% elif codec.sign_extend_shift is not none %}
                can_data.{{ entry.msg.name }}.{{ codec.signal.name }} = ({{ codec.signal.c_type }})CAN_sign_extend_raw(sig_raw_{{ codec.signal.name }}, {{ codec.signal.length }});
                {% else %}
                can_data.{{ entry.msg.name }}.{{ codec.signal.name }} = ({{ codec.signal.c_type }})sig_raw_{{ codec.signal.name }};
                {% endif %}
                {% endfor %}

                can_data.{{ entry.msg.name }}.last_rx = OS_TICKS;
                {% if entry.rx_msg.callback %}
                {{ entry.rx_msg.name }}_CALLBACK();
                {% endif %}
                break;
            }
            {% endfor %}
            default:
                break;
        }
    }
    {% endfor %}
}
