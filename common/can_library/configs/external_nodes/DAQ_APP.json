{
    "node_name": "DAQ_APP",
    "bus_name": "CCAN",
    "tx": [
        {
            "msg_name": "charge_request",
            "msg_desc": "Message from DAQ App to A_BOX to request charging",
            "signals": [
                {
                    "sig_name": "charge_enable",
                    "sig_desc": "Request to start charging",
                    "type": "bool"
                },
                {
                    "sig_name": "charge_volts",
                    "sig_desc": "Requested charge voltage in decivolts",
                    "type": "uint16_t",
                    "unit": "V",
                    "scale": 0.1
                },
                {
                    "sig_name": "charge_current",
                    "sig_desc": "Requested charge current in deciamps",
                    "type": "uint16_t",
                    "unit": "A",
                    "scale": 0.1
                }
            ],
            "msg_period": 500,
            "msg_priority": 3
        }
    ],
    "rx": []
}