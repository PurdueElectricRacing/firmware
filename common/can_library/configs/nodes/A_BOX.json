{
    "node_name": "A_BOX",
    "scheduler": "freertos",
    "busses": {
        "VCAN": {
            "peripheral": "FDCAN1",
            "tx": [
                {
                    "msg_name": "precharge_hb",
                    "msg_desc": "heart beat for precharge",
                    "signals": [
                        {
                            "sig_name": "IMD",
                            "sig_desc": "Fault State of IMD",
                            "type": "uint8_t"
                        },
                        {
                            "sig_name": "BMS",
                            "sig_desc": "Fault State of BMS",
                            "type": "uint8_t"
                        }
                    ],
                    "msg_period": 500,
                    "msg_priority": 2
                },
                {
                    "msg_name": "abox_version",
                    "msg_desc": "ABox version",
                    "signals": [
                        {
                            "sig_name": "git_hash",
                            "type": "uint32_t",
                            "sig_desc": "int representation of git short hash"
                        }
                    ],
                    "msg_priority": 5,
                    "msg_period": 5000
                }
            ],
            "rx": [],
            "accept_all_messages": false
        },
        "CCAN": {
            "peripheral": "FDCAN2",
            "tx": [],
            "rx": [
                {
                    "msg_name": "elcon_charger_status"
                }
            ],
            "accept_all_messages": false
        }
    },
    "fault_library_enabled": true,
    "generate_fault_messages": false,
    "faults": [
        {
            "fault_name": "pack_temp",
            "max": 500,
            "min": 0,
            "priority": "warning",
            "time_to_latch": 2000,
            "time_to_unlatch": 5000,
            "lcd_message": "Pack Temp High (> 50)"
        },
        {
            "fault_name": "pack_temp_exceeded",
            "max": 600,
            "min": 0,
            "priority": "error",
            "time_to_latch": 500,
            "time_to_unlatch": 10000,
            "lcd_message": "Pack Overheating"
        },
        {
            "fault_name": "min_pack_temp",
            "max": 10000,
            "min": 100,
            "priority": "error",
            "time_to_latch": 2000,
            "time_to_unlatch": 10000,
            "lcd_message": "Pack Minimum temp < 10"
        },
        {
            "fault_name": "imd",
            "max": 1,
            "min": 0,
            "priority": "fatal",
            "time_to_latch": 100,
            "time_to_unlatch": 5000,
            "lcd_message": "IMD Isolation Fault"
        },
        {
            "fault_name": "tmu_power_lost",
            "max": 5,
            "min": 3,
            "priority": "error",
            "time_to_latch": 100,
            "time_to_unlatch": 5000,
            "lcd_message": "Poopy! TMU Power Lost!"
        }
    ]
}
