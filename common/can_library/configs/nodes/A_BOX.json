{
    "node_name": "A_BOX",
    "busses": {
        "VCAN": {
            "peripheral": "FDCAN1",
            "tx": [
                {
                    "msg_name": "pack_stats",
                    "msg_desc": "Pack voltage, current, and temperature",
                    "signals": [
                        {
                            "sig_name": "pack_voltage",
                            "sig_desc": "Total pack voltage",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.01
                        },
                        {
                            "sig_name": "pack_current",
                            "sig_desc": "Total pack current, positive is discharge",
                            "type": "int16_t",
                            "unit": "A",
                            "scale": 0.1
                        },
                        {
                            "sig_name": "avg_temp",
                            "sig_desc": "Average cell temperature in the pack",
                            "type": "int16_t",
                            "unit": "C",
                            "scale": 0.01
                        }
                    ],
                    "msg_priority": 5,
                    "msg_period": 10
                },
                {
                    "msg_name": "module_voltage_stats",
                    "msg_desc": "Rotating module voltage statistics",
                    "signals": [
                        {
                            "sig_name": "module_index",
                            "sig_desc": "Module index in the daisy chain",
                            "type": "uint8_t",
                            "unit": "idx",
                            "length": 8
                        },
                        {
                            "sig_name": "min_voltage",
                            "sig_desc": "Minimum cell voltage in the module",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.005
                        },
                        {
                            "sig_name": "max_voltage",
                            "sig_desc": "Maximum cell voltage in the module",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.005
                        },
                        {
                            "sig_name": "sum_voltage",
                            "sig_desc": "Sum of cell voltages in the module",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.005
                        }
                    ],
                    "msg_priority": 4,
                    "msg_period": 250
                },
                {
                    "msg_name": "module_temp_balance_stats",
                    "msg_desc": "Rotating module temperature and balancing statistics",
                    "signals": [
                        {
                            "sig_name": "module_index",
                            "sig_desc": "Module index in the daisy chain",
                            "type": "uint8_t",
                            "unit": "idx",
                            "length": 8
                        },
                        {
                            "sig_name": "max_temp",
                            "sig_desc": "Maximum thermistor temperature in the module",
                            "type": "int16_t",
                            "unit": "C",
                            "scale": 0.01
                        },
                        {
                            "sig_name": "balancing_mask",
                            "sig_desc": "Bitmask of cells currently enabled for balancing",
                            "type": "uint16_t",
                            "length": 16
                        }
                    ],
                    "msg_priority": 4,
                    "msg_period": 250
                },
                {
                    "msg_name": "module_sample",
                    "msg_desc": "Rotating individual module cell voltage or thermistor sample",
                    "signals": [
                        {
                            "sig_name": "module_index",
                            "sig_desc": "Module index in the daisy chain",
                            "type": "uint8_t",
                            "unit": "idx",
                            "length": 8
                        },
                        {
                            "sig_name": "sample_index",
                            "sig_desc": "Cell or thermistor index within the module",
                            "type": "uint8_t",
                            "unit": "idx",
                            "length": 8
                        },
                        {
                            "sig_name": "is_temp",
                            "sig_desc": "True when sample_value is a thermistor temperature, false for a cell voltage",
                            "unit": "bool",
                            "type": "bool"
                        },
                        {
                            "sig_name": "sample_value",
                            "sig_desc": "Sample reading in volts or Celsius depending on is_temp",
                            "type": "int16_t",
                            "unit": "V or C",
                            "scale": 0.005
                        }
                    ],
                    "msg_priority": 4,
                    "msg_period": 40
                },
                {
                    "msg_name": "abox_version",
                    "msg_desc": "ABox version",
                    "signals": [
                        {
                            "sig_name": "git_hash",
                            "type": "uint32_t",
                            "unit": "hash",
                            "sig_desc": "int representation of git short hash"
                        }
                    ],
                    "msg_priority": 5,
                    "msg_period": 5000
                }
            ],
            "rx": [],
            "accept_all_messages": false
        },
        "CCAN": {
            "peripheral": "FDCAN2",
            "tx": [
                {
                    "msg_name": "elcon_command",
                    "msg_desc": "Command from A_BOX to Elcon Charger (Message1)",
                    "signals": [
                        {
                            "sig_name": "voltage_limit",
                            "sig_desc": "Requested charge voltage in decivolts",
                            "unit": "V",
                            "scale": 0.1,
                            "type": "uint16_t",
                            "length": 16
                        },
                        {
                            "sig_name": "current_limit",
                            "sig_desc": "Requested charge current in deciamps",
                            "unit": "A",
                            "scale": 0.1,
                            "type": "uint16_t",
                            "length": 16
                        },
                        {
                            "sig_name": "charger_disable",
                            "sig_desc": "0 to enable charging, 1 to disable charging",
                            "type": "bool"
                        }
                    ],
                    "msg_priority": 3,
                    "msg_id_override": "0x1806E5F4",
                    "msg_period": 1000
                },
                {
                    "msg_name": "charging_telemetry",
                    "msg_desc": "Reported battery stats during charging",
                    "signals": [
                        {
                            "sig_name": "pack_voltage",
                            "sig_desc": "Total pack voltage",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.1
                        },
                        {
                            "sig_name": "min_cell_voltage",
                            "sig_desc": "Minimum cell voltage in the pack",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.01
                        },
                        {
                            "sig_name": "max_cell_voltage",
                            "sig_desc": "Maximum cell voltage in the pack",
                            "type": "uint16_t",
                            "unit": "V",
                            "scale": 0.01
                        },
                        {
                            "sig_name": "charging_state",
                            "sig_desc": "abox charging fsm state",
                            "type": "charging_state_t"
                        }
                    ],
                    "msg_priority": 5,
                    "msg_period": 1000
                }
            ],
            "rx": [
                {
                    "msg_name": "elcon_status"
                },
                {
                    "msg_name": "charge_request"
                }
            ],
            "accept_all_messages": false
        }
    },
    "fault_library_enabled": true,
    "generate_fault_messages": false,
    "faults": [
        {
            "fault_name": "PACK_OVERTEMP",
            "max": 60,
            "min": 0,
            "priority": "error",
            "time_to_latch": 500,
            "time_to_unlatch": 10000,
            "lcd_message": "Pack Temp > 60C"
        },
        {
            "fault_name": "PACK_WARM",
            "max": 50,
            "min": 0,
            "priority": "warning",
            "time_to_latch": 2000,
            "time_to_unlatch": 5000,
            "lcd_message": "Pack Temp > 50C"
        },
        {
            "fault_name": "PACK_COLD",
            "max": 10,
            "min": 0,
            "priority": "error",
            "time_to_latch": 2000,
            "time_to_unlatch": 10000,
            "lcd_message": "Pack Temp < 10C"
        },
        {
            "fault_name": "IMD",
            "max": 1,
            "min": 0,
            "priority": "error",
            "time_to_latch": 100,
            "time_to_unlatch": 5000,
            "lcd_message": "IMD Isolation Fault"
        },
        {
            "fault_name": "BMS_DISCONNECTED",
            "max": 1,
            "min": 0,
            "priority": "error",
            "time_to_latch": 5000,
            "time_to_unlatch": 1000,
            "lcd_message": "BMS Disconnected"
        },
        {
            "fault_name": "CELL_UNDERVOLTAGE",
            "max": 42,
            "min": 27,
            "priority": "error",
            "time_to_latch": 1000,
            "time_to_unlatch": 5000,
            "lcd_message": "Min Cell Voltage < 2.7V"
        },
        {
            "fault_name": "PACK_FULL",
            "max": 520,
            "min": 0,
            "priority": "warning",
            "time_to_latch": 10000,
            "time_to_unlatch": 10000,
            "lcd_message": "Pack Full"
        }
    ]
}
