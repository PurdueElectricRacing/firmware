{
    "node_name": "BL_MAIN_MODULE",
    "busses": {
        "VCAN": {
            "peripheral": "FDCAN2",
            "tx": [
                {
                    "msg_name": "bl_main_module_resp",
                    "msg_desc": "Bootloader response for main module",
                    "signals": [
                        {
                            "sig_name": "status",
                            "type": "uint8_t"
                        },
                        {
                            "sig_name": "detail",
                            "type": "uint32_t"
                        }
                    ],
                    "msg_id_override": "0x182",
                    "msg_priority": 0
                }
            ],
            "rx": [
                {
                    "msg_name": "bl_main_module_cmd",
                    "callback": true
                },
                {
                    "msg_name": "bl_main_module_data",
                    "callback": true
                }
            ]
        }
    },
    "fault_library_enabled": false
}
