{
    "node_name": "DASHBOARD",
    "busses": {
        "VCAN": {
            "peripheral": "FDCAN2",
            "tx": [
                {
                    "msg_name": "pedals",
                    "msg_desc": "Pedal values",
                    "signals": [
                        {
                            "sig_name": "throttle",
                            "sig_desc": "Throttle request from driver",
                            "type": "uint16_t",
                            "length": 12,
                            "scale": 0.02442,
                            "unit": "%"
                        },
                        {
                            "sig_name": "brake",
                            "sig_desc": "Brake request from driver",
                            "type": "uint16_t",
                            "length": 12,
                            "scale": 0.02442,
                            "unit": "%"
                        }
                    ],
                    "msg_period": 15,
                    "msg_priority": 2
                },
                {
                    "msg_name": "start_button",
                    "msg_desc": "Car start button",
                    "signals": [
                        {
                            "sig_name": "is_pressed",
                            "type": "bool"
                        }
                    ],
                    "msg_period": 300,
                    "msg_priority": 1
                },
                {
                    "msg_name": "dash_version",
                    "msg_desc": "Dashboard version",
                    "signals": [
                        {
                            "sig_name": "git_hash",
                            "type": "uint32_t",
                            "sig_desc": "int representation of git short hash"
                        }
                    ],
                    "msg_priority": 5,
                    "msg_period": 5000
                }
            ],
            "rx": [
                {
                    "msg_name": "main_hb"
                },
                {
                    "msg_name": "pack_stats"
                },
                {
                    "msg_name": "wheel_speeds"
                },
                {
                    "msg_name": "motor_temps"
                },
                {
                    "msg_name": "igbt_temps"
                }
            ]
        },
        "SCAN": {
            "peripheral": "FDCAN1",
            "tx": [
                {
                    "msg_name": "LWS_Config",
                    "msg_desc": "Steering sensor configuration",
                    "signals": [
                        {
                            "sig_name": "CCW",
                            "type": "uint8_t",
                            "length": 3
                        },
                        {
                            "sig_name": "Reserved_1",
                            "type": "uint8_t",
                            "length": 5
                        },
                        {
                            "sig_name": "Reserved_2",
                            "type": "uint8_t",
                            "length": 8
                        }
                    ],
                    "msg_period": 0,
                    "msg_id_override": "0x7C0",
                    "msg_priority": 3
                }
            ],
            "rx": [
                {
                    "msg_name": "LWS_Standard"
                }
            ]
        }
    },
    "fault_library_enabled": true,
    "generate_fault_messages": true,
    "faults": [
        {
            "fault_name": "APPS_wiring_t1",
            "max": 1500,
            "min": 100,
            "priority": "error",
            "time_to_latch": 200,
            "time_to_unlatch": 1000,
            "lcd_message": "APPS Wiring Fail T1"
        },
        {
            "fault_name": "APPS_wiring_t2",
            "max": 1500,
            "min": 100,
            "priority": "error",
            "time_to_latch": 200,
            "time_to_unlatch": 1000,
            "lcd_message": "APPS Wiring Fail T2"
        },
        {
            "fault_name": "BSE",
            "max": 1,
            "min": 0,
            "priority": "error",
            "time_to_latch": 100,
            "time_to_unlatch": 1000,
            "lcd_message": "Brake Wiring Fail (BSE)"
        },
        {
            "fault_name": "bspd",
            "max": 182,
            "min": 0,
            "priority": "error",
            "time_to_latch": 100,
            "time_to_unlatch": 1000,
            "lcd_message": "BSE Wiring Fail B2"
        },
        {
            "fault_name": "APPS_IMPLAUSIBLE",
            "max": 409,
            "min": 0,
            "priority": "error",
            "time_to_latch": 500,
            "time_to_unlatch": 50,
            "lcd_message": "APPS Implaus Detected"
        },
        {
            "fault_name": "APPS_BRAKE",
            "max": 1,
            "min": 0,
            "priority": "warning",
            "time_to_latch": 100,
            "time_to_unlatch": 100,
            "lcd_message": "Release Both Pedals"
        }
    ]
}
