{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "unevaluatedProperties": false,
    "$defs": {
        "tx_message": {
            "type": "object",
            "required": ["msg_name", "msg_desc", "signals", "msg_priority"],
            "unevaluatedProperties": false,
            "properties": {
                "msg_name": { "type": "string" },
                "msg_desc": { "type": "string" },
                "msg_priority": { "type": "integer", "minimum": 0, "maximum": 5 },
                "msg_period": { "type": "integer", "minimum": 0 },
                "msg_id_override": { 
                    "type": "string",
                    "pattern": "^0x[0-9a-fA-F]{1,8}$"
                },
                "signals": {
                    "type": "array",
                    "items": { "$ref": "https://github.com/PER/canpiler/signal_schema.json" }
                }
            }
        },
        "rx_message": {
            "type": "object",
            "required": ["msg_name"],
            "unevaluatedProperties": false,
            "properties": {
                "msg_name": { "type": "string" },
                "callback": { "type": "boolean" },
                "irq": { "type": "boolean" }
            }
        }
    }
}
