{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/PER/canpiler/signal_schema.json",
    "type": "object",
    "required": ["sig_name", "type"],
    "unevaluatedProperties": false,
    "properties": {
        "sig_name": { "type": "string" },
        "sig_desc": { "type": "string" },
        "type": { "type": "string" },
        "length": { "type": "integer", "minimum": 1, "maximum": 64 },
        "scale": { "type": "number" },
        "offset": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "unit": { "type": "string" },
        "choices": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
    },
    "allOf": [
        {
            "if": { "properties": { "type": { "const": "float" } } },
            "then": { "properties": { "length": { "const": 32 } } }
        },
        {
            "if": { "properties": { "type": { "const": "double" } } },
            "then": { "properties": { "length": { "const": 64 } } }
        },
        {
            "if": { "required": ["scale"] },
            "then": { "required": ["unit"] }
        }
    ]
}